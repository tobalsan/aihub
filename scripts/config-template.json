{
  "version": 2,
  "agents": [
    {
      "id": "devagent",
      "name": "DevAgent",
      "description": "Test Agent for development",
      "avatar": "🤖",
      "workspace": "agents/devagent",
      "sdk": "pi",
      "model": {
        "provider": "zai",
        "model": "glm-5.1"
      },
      "queueMode": "queue"
    }
  ],
  "subagents": [
    {
      "name": "Worker",
      "description": "Implements code in isolated worktree",
      "cli": "codex",
      "model": "gpt-5.3-codex",
      "reasoning": "medium",
      "type": "worker",
      "runMode": "worktree"
    },
    {
      "name": "Reviewer",
      "description": "Review code in worker worktree",
      "cli": "codex",
      "model": "gpt-5.5",
      "reasoning": "high",
      "type": "reviewer",
      "runMode": "none"
    }
  ],
  "extensions": {
    "projects": {
      "orchestrator": {
        "enabled": true,
        "poll_interval_ms": 15000,
        "failure_cooldown_ms": 60000,
        "statuses": {
          "todo": {
            "profile": "Worker",
            "max_concurrent": 1
          },
          "review": {
            "profile": "Reviewer",
            "max_concurrent": 1
          }
        }
      },
      "root": __PROJECTS_ROOT__,
    }
  },
  "gateway": {
    "bind": "loopback",
    "port": __GATEWAY_PORT__
  },
  "sessions": {
    "idleMinutes": 360
  },
  "ui": {
    "bind": "loopback",
    "port": __UI_PORT__
  },
  "apiUrl": "http://127.0.0.1:__GATEWAY_PORT__/aihub"
}
