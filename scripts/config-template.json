{
  "version": 3,
  "extensions": {
    "subagents": {
      "profiles": [
        {
          "name": "Worker",
          "description": "Implements code in isolated worktree",
          "cli": "codex",
          "model": "gpt-5.3-codex",
          "reasoning": "medium",
          "type": "worker",
          "runMode": "worktree"
        },
        {
          "name": "Reviewer",
          "description": "Review code in worker worktree",
          "cli": "codex",
          "model": "gpt-5.5",
          "reasoning": "high",
          "type": "reviewer",
          "runMode": "none"
        },
        {
          "name": "Merger",
          "description": "Merge ready slices into the project integration branch",
          "cli": "codex",
          "model": "gpt-5.5",
          "reasoning": "medium",
          "type": "merger",
          "runMode": "worktree"
        }
      ]
    },
    "scheduler": {},
    "orchestrator": {
      "projectsRoot": "./projects",
      "projects": [
        "./projects/projectA",
        "./projects/projectB"
      ]
    }
  },
  "notifications": {
    "channels": {
      "default": {
        "slack": "dev-null"
      }
    }
  },
  "gateway": {
    "bind": "loopback",
    "port": __GATEWAY_PORT__
  },
  "sessions": {
    "idleMinutes": 360
  },
  "ui": {
    "bind": "loopback",
    "port": __UI_PORT__
  },
  "apiUrl": "http://127.0.0.1:__GATEWAY_PORT__/aihub",
  "agents": [
    "agents/devagent"
  ]
}
